{
  "name": "charterwell",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/generate-sitemap.mjs && next build",
    "start": "next start",
    "lint": "next lint",
    "deploy:cf": "npm run build && npm run cf:pages:deploy",
    "cf:pages:deploy": "wrangler pages deploy out --project-name=charterwell --commit-dirty=true"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "next": "^16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "wrangler": "^4.54.0"
  }
}
